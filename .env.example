# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=payments_secret

# ─── Keycloak ─────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_PASSWORD=admin_secret

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_secret

# ─── n8n ──────────────────────────────────────────────────────────────────────
N8N_USER=n8n_admin
N8N_PASSWORD=n8n_secret
N8N_ENCRYPTION_KEY=n8n_encrypt_key_32chars_minimum!!

# ─── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=grafana_secret

# ─── Backend ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://payments_user:payments_secret@localhost:5432/payments_db
JWT_SECRET=super_secret_jwt_key_change_in_production
KEYCLOAK_URL=http://localhost:8080/auth
KEYCLOAK_REALM=payments
KEYCLOAK_CLIENT_ID=payments-portal
KEYCLOAK_CLIENT_SECRET=your_keycloak_client_secret

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_secret
MINIO_REPORTS_BUCKET=reports
MINIO_LOGOS_BUCKET=logos
MINIO_EXPORTS_BUCKET=exports

OPENSEARCH_URL=http://localhost:9200

N8N_WEBHOOK_URL=http://localhost:5678/webhook

LOKI_URL=http://localhost:3100

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=smtp_password
SMTP_FROM=noreply@example.com

PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost/auth
NEXT_PUBLIC_KEYCLOAK_REALM=payments
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=payments-portal
NEXT_PUBLIC_APP_NAME=Payments Data Portal

# ─── Seed ─────────────────────────────────────────────────────────────────────
SEED_TRANSACTION_COUNT=5000000
SEED_YEARS_OF_DATA=3

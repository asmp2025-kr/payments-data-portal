# Exclude everything not needed for the Docker build
# This dramatically speeds up build context upload to Railway

# Node modules (hundreds of thousands of files)
**/node_modules/
node_modules/
apps/backend/node_modules/
apps/frontend/node_modules/

# Frontend (not needed for backend build)
apps/frontend/

# Local build artifacts (we copy apps/backend/dist explicitly)
apps/frontend/.next/
apps/frontend/out/

# Local env files (never ship secrets)
.env
.env.local
**/.env
**/.env.local
**/.env.production

# Git
.git/
.gitignore

# Logs
**/*.log
logs/

# Test files
**/*.spec.ts
**/*.test.ts
**/test/
**/coverage/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/

# Temp
tmp/
temp/

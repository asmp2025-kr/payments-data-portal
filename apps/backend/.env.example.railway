# Copy these into Railway → Project → Variables

NODE_ENV=production
PORT=3000

# From Supabase: Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# Generate a strong random secret (e.g. openssl rand -hex 32)
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_64_CHARS

JWT_EXPIRY=8h

# Your Vercel frontend URL
CORS_ORIGINS=https://payments-data-portal.vercel.app,http://localhost:4000

# Disable cloud-unavailable services
DISABLE_MINIO=true
DISABLE_OPENSEARCH=true
DISABLE_N8N=true
DISABLE_LOKI=true
DISABLE_PUPPETEER=true

# ─── Frontend Cloud Environment (Vercel) ─────────────────────────────────────
# Replace RAILWAY_BACKEND_URL with your actual Railway deployment URL

NEXT_PUBLIC_API_URL=https://YOUR_RAILWAY_APP.railway.app/api
NEXT_PUBLIC_APP_NAME=Payments Data Portal
NEXT_PUBLIC_USE_SIMPLE_AUTH=true

# Keycloak disabled — using built-in JWT login
NEXT_PUBLIC_AUTH_MODE=jwt
